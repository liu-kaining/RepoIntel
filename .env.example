# RepoIntel environment example
# Copy this file to .env for local use. Never commit real secrets.

# -----------------------------
# Runtime mode
# -----------------------------
# true: use built-in sample repositories and heuristic audit, no external API calls.
# false: real GitHub + LLM + state backend.
REPOINTEL_DRY_RUN=true

# -----------------------------
# GitHub
# -----------------------------
# Optional locally, recommended in production to increase GitHub API rate limits.
# In GitHub Actions, GITHUB_TOKEN is injected automatically.
GITHUB_TOKEN=

# -----------------------------
# LLM provider
# -----------------------------
# openai: OpenAI-compatible Chat Completions API, including OpenAI/DeepSeek/proxies.
# claude: Anthropic Messages API, including Anthropic-compatible endpoints.
LLM_PROVIDER=openai
LLM_MODEL=
LLM_API_KEY=

# Optional OpenAI/Claude-compatible base URL.
# Examples: OpenAI-compatible gateway, private proxy, or custom model service.
LLM_BASE_URL=

# Optional cheaper model for Layer 2 rough screening.
# If empty, RepoIntel reuses LLM_MODEL.
ROUGH_LLM_MODEL=

# -----------------------------
# State backend
# -----------------------------
# r2: Cloudflare R2, required for production serverless dedupe.
# local: local JSON file, useful for development.
REPOINTEL_STATE_BACKEND=local
REPOINTEL_LOCAL_STATE=output/processed_repos.json

# Cloudflare R2 settings. Required when REPOINTEL_STATE_BACKEND=r2 and not dry-run.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_CACHE_KEY=processed_repos.json

# -----------------------------
# Output paths
# -----------------------------
HUGO_CONTENT_DIR=hugo-site/content/posts
REPOINTEL_OUTPUT_DIR=output

# -----------------------------
# Pipeline limits and quality gates
# -----------------------------
REPOINTEL_MAX_CANDIDATES=100
REPOINTEL_ROUGH_LIMIT=15
REPOINTEL_FINAL_LIMIT=10
REPOINTEL_SCORE_THRESHOLD=75
REPOINTEL_CACHE_TTL_DAYS=14
REPOINTEL_MIN_FORK_STAR_RATIO=0.01
REPOINTEL_MIN_STARS=300
REPOINTEL_MIN_STARS_WEEK=100
REPOINTEL_MAX_REPO_AGE_DAYS=30
REPOINTEL_RECENT_PUSH_HOURS=48

# -----------------------------
# Deep code audit (required)
# -----------------------------
# auto: shallow git clone first, fallback to GitHub API
# git:  always clone --depth 1 and read files from disk
# api:  GitHub Trees/Contents API only
REPOINTEL_CODE_SOURCE=auto
REPOINTEL_MAX_CODE_FILES=48
REPOINTEL_MAX_FILE_BYTES=48000
REPOINTEL_MAX_TOTAL_CODE_CHARS=600000
REPOINTEL_MIN_CODE_FILES=5
REPOINTEL_GIT_CLONE_TIMEOUT=300
